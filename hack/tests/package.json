{
  "name": "e2e-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node ./scripts/run-suite.mjs full",
    "test:smoke": "node ./scripts/run-suite.mjs smoke",
    "test:module": "node ./scripts/run-suite.mjs module",
    "test:sqlite": "node ./scripts/run-sqlite-suite.mjs",
    "test:sqlite:e2e-smoke": "node ./scripts/run-sqlite-suite.mjs smoke",
    "test:full": "node ./scripts/run-suite.mjs full",
    "test:validate": "node ./scripts/validate-e2e.mjs",
    "test:service-deps": "node ./scripts/validate-service-dependencies.mjs && node ./scripts/validate-service-dependencies-test.mjs",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
