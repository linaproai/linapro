{
  "plugins": {
    "monitor_server": {
      "api": {
        "monitor": {
          "v1": {
            "CPUMetrics": {
              "fields": {
                "cores": {
                  "dc": "CPU核心數"
                },
                "modelName": {
                  "dc": "CPU型號"
                },
                "usagePercent": {
                  "dc": "CPU使用率（百分比）"
                }
              }
            },
            "DBMetrics": {
              "fields": {
                "idle": {
                  "dc": "空閒連接數"
                },
                "inUse": {
                  "dc": "使用中連接數"
                },
                "maxOpenConns": {
                  "dc": "最大連接數"
                },
                "openConns": {
                  "dc": "當前打開連接數"
                },
                "version": {
                  "dc": "數據庫版本"
                }
              }
            },
            "DiskMetrics": {
              "fields": {
                "free": {
                  "dc": "可用容量（字節）"
                },
                "fsType": {
                  "dc": "文件系統類型"
                },
                "path": {
                  "dc": "掛載點路徑"
                },
                "total": {
                  "dc": "總容量（字節）"
                },
                "usagePercent": {
                  "dc": "使用率（百分比）"
                },
                "used": {
                  "dc": "已用容量（字節）"
                }
              }
            },
            "GoMetrics": {
              "fields": {
                "gcPauseNs": {
                  "dc": "最近一次GC暫停時間（納秒）"
                },
                "gfVersion": {
                  "dc": "GoFrame版本"
                },
                "goroutines": {
                  "dc": "Goroutine數量"
                },
                "processCpu": {
                  "dc": "服務CPU使用率（百分比）"
                },
                "processMemory": {
                  "dc": "服務內存使用率（百分比）"
                },
                "serviceUptime": {
                  "dc": "服務運行時長"
                },
                "version": {
                  "dc": "Go版本"
                }
              }
            },
            "MemoryMetrics": {
              "fields": {
                "available": {
                  "dc": "可用內存（字節）"
                },
                "total": {
                  "dc": "總內存（字節）"
                },
                "usagePercent": {
                  "dc": "內存使用率（百分比）"
                },
                "used": {
                  "dc": "已用內存（字節）"
                }
              }
            },
            "NetMetrics": {
              "fields": {
                "bytesRecv": {
                  "dc": "總接收字節數"
                },
                "bytesSent": {
                  "dc": "總髮送字節數"
                },
                "recvRate": {
                  "dc": "接收速率（字節/秒）"
                },
                "sendRate": {
                  "dc": "發送速率（字節/秒）"
                }
              }
            },
            "ServerBasic": {
              "fields": {
                "arch": {
                  "dc": "系統架構"
                },
                "bootTime": {
                  "dc": "系統啟動時間"
                },
                "hostname": {
                  "dc": "主機名"
                },
                "os": {
                  "dc": "操作系統"
                },
                "startTime": {
                  "dc": "服務啟動時間"
                },
                "uptime": {
                  "dc": "系統運行時長（秒）"
                }
              }
            },
            "ServerMonitorReq": {
              "fields": {
                "nodeName": {
                  "dc": "按節點名稱過濾，不傳則返回所有節點"
                }
              },
              "meta": {
                "dc": "查詢服務器監控數據，返回各節點最新的CPU、內存、磁盤、網絡、Go運行時等指標信息",
                "summary": "服務監控",
                "tags": "系統監控"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "dbInfo": {
                              "dc": "數據庫指標信息"
                            },
                            "nodes": {
                              "dc": "各節點監控數據"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "查詢服務器監控數據，返回各節點最新的CPU、內存、磁盤、網絡、Go運行時等指標信息"
              }
            },
            "ServerMonitorRes": {
              "fields": {
                "dbInfo": {
                  "dc": "數據庫指標信息"
                },
                "nodes": {
                  "dc": "各節點監控數據"
                }
              }
            },
            "ServerNodeInfo": {
              "fields": {
                "collectAt": {
                  "dc": "數據上報時間"
                },
                "cpu": {
                  "dc": "CPU指標"
                },
                "disks": {
                  "dc": "磁盤使用情況"
                },
                "goInfo": {
                  "dc": "Go運行時指標"
                },
                "memory": {
                  "dc": "內存指標"
                },
                "network": {
                  "dc": "網絡流量指標"
                },
                "nodeIp": {
                  "dc": "節點IP地址"
                },
                "nodeName": {
                  "dc": "節點名稱（hostname）"
                },
                "server": {
                  "dc": "服務器基本信息"
                }
              }
            }
          }
        }
      }
    }
  }
}
