{
  "plugins": {
    "monitor_operlog": {
      "api": {
        "operlog": {
          "v1": {
            "CleanReq": {
              "fields": {
                "beginTime": {
                  "dc": "清理起始時間"
                },
                "endTime": {
                  "dc": "清理截止時間"
                }
              },
              "meta": {
                "dc": "清空指定時間範圍內的操作日誌，不傳時間則清空全部",
                "summary": "清空操作日誌",
                "tags": "操作日誌"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "deleted": {
                              "dc": "實際刪除的記錄數"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "清空指定時間範圍內的操作日誌，不傳時間則清空全部"
              }
            },
            "CleanRes": {
              "fields": {
                "deleted": {
                  "dc": "實際刪除的記錄數"
                }
              }
            },
            "DeleteReq": {
              "fields": {
                "ids": {
                  "dc": "日誌ID，多個用逗號分隔"
                }
              },
              "meta": {
                "dc": "刪除一條或多條操作日誌記錄",
                "summary": "刪除操作日誌",
                "tags": "操作日誌"
              },
