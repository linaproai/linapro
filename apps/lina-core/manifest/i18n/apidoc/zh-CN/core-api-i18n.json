{
  "core": {
    "api": {
      "i18n": {
        "v1": {
          "DiagnoseMessagesReq": {
            "fields": {
              "keyPrefix": {
                "dc": "按翻译键前缀过滤，如 menu.、plugin.demo.；不传则诊断全部"
              },
              "locale": {
                "dc": "目标语言编码，不传时按请求上下文自动解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "诊断目标语言每个翻译键的实际命中来源、是否回退到默认语言以及最终生效的语言，便于排查覆写优先级与缺失翻译问题",
              "summary": "诊断翻译来源",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "defaultLocale": {
                            "dc": "当前宿主默认语言编码"
                          },
                          "items": {
                            "dc": "翻译来源诊断结果列表"
                          },
                          "locale": {
                            "dc": "目标语言编码"
                          },
                          "total": {
                            "dc": "诊断返回的翻译键数量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "诊断目标语言每个翻译键的实际命中来源、是否回退到默认语言以及最终生效的语言，便于排查覆写优先级与缺失翻译问题"
            }
          },
          "DiagnoseMessagesRes": {
            "fields": {
              "defaultLocale": {
                "dc": "当前宿主默认语言编码"
              },
              "items": {
                "dc": "翻译来源诊断结果列表"
              },
              "locale": {
                "dc": "目标语言编码"
              },
              "total": {
                "dc": "诊断返回的翻译键数量"
              }
            }
          },
          "ExportMessagesReq": {
            "fields": {
              "locale": {
                "dc": "目标语言编码，不传时按请求上下文自动解析，如 zh-CN、en-US"
              },
              "raw": {
                "dc": "是否仅导出当前语言原始资源：true=仅导出当前语言聚合结果 false=导出带默认语言回退的有效结果"
              }
            },
            "meta": {
              "dc": "导出指定语言的扁平国际化消息集合，支持导出有效聚合结果或当前语言原始资源，用于交付维护、离线校对和再次导入",
              "summary": "导出国际化消息",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "defaultLocale": {
                            "dc": "当前宿主默认语言编码"
                          },
                          "locale": {
                            "dc": "本次导出的目标语言编码"
                          },
                          "messages": {
                            "dc": "按扁平 key 输出的国际化消息集合"
                          },
                          "mode": {
                            "dc": "导出模式：effective=带默认语言回退的有效结果 raw=当前语言原始资源"
                          },
                          "total": {
                            "dc": "导出的翻译键数量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "导出指定语言的扁平国际化消息集合，支持导出有效聚合结果或当前语言原始资源，用于交付维护、离线校对和再次导入"
            }
          },
          "ExportMessagesRes": {
            "fields": {
              "defaultLocale": {
                "dc": "当前宿主默认语言编码"
              },
              "locale": {
                "dc": "本次导出的目标语言编码"
              },
              "messages": {
                "dc": "按扁平 key 输出的国际化消息集合"
              },
              "mode": {
                "dc": "导出模式：effective=带默认语言回退的有效结果 raw=当前语言原始资源"
              },
              "total": {
                "dc": "导出的翻译键数量"
              }
            }
          },
          "ImportMessagesReq": {
            "fields": {
              "locale": {
                "dc": "目标语言编码，如 zh-CN、en-US"
              },
              "messages": {
                "dc": "按扁平 key 组织的翻译键值集合"
              },
              "overwrite": {
                "dc": "遇到同 scope 下已存在的翻译键时是否覆盖：true=覆盖 false=跳过"
              },
              "remark": {
                "dc": "本次导入备注，便于后续诊断与追踪"
              },
              "scopeKey": {
                "dc": "作用域标识，如 core、project-code、plugin-id"
              },
              "scopeType": {
                "dc": "作用域类型：host=宿主 project=项目 plugin=插件 business=业务"
              }
            },
            "meta": {
              "dc": "按语言将扁平翻译键批量导入到数据库覆写表，支持宿主、项目或插件等不同作用域，适用于交付项目上线后批量修订文案",
              "summary": "导入国际化消息",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "created": {
                            "dc": "新建翻译键数量"
                          },
                          "imported": {
                            "dc": "请求中处理的翻译键总数"
                          },
                          "locale": {
                            "dc": "本次导入的目标语言编码"
                          },
                          "skipped": {
                            "dc": "因关闭覆盖而跳过的翻译键数量"
                          },
                          "updated": {
                            "dc": "覆盖更新的翻译键数量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "按语言将扁平翻译键批量导入到数据库覆写表，支持宿主、项目或插件等不同作用域，适用于交付项目上线后批量修订文案"
            }
          },
          "ImportMessagesRes": {
            "fields": {
              "created": {
                "dc": "新建翻译键数量"
              },
              "imported": {
                "dc": "请求中处理的翻译键总数"
              },
              "locale": {
                "dc": "本次导入的目标语言编码"
              },
              "skipped": {
                "dc": "因关闭覆盖而跳过的翻译键数量"
              },
              "updated": {
                "dc": "覆盖更新的翻译键数量"
              }
            }
          },
          "MessageDiagnosticItem": {
            "fields": {
              "effectiveLocale": {
                "dc": "实际提供该翻译值的语言编码"
              },
              "fromFallback": {
                "dc": "是否回退到默认语言：true=是 false=否"
              },
              "key": {
                "dc": "翻译键"
              },
              "requestedLocale": {
                "dc": "请求的目标语言编码"
              },
              "sourceKey": {
                "dc": "命中来源标识，如 core、plugin-id 或具体作用域键"
              },
              "sourceType": {
                "dc": "命中来源类型：host_file=宿主文件 plugin_file=插件文件 database=数据库覆写"
              },
              "value": {
                "dc": "当前最终生效的翻译值"
              }
            }
          },
          "MissingMessageItem": {
            "fields": {
              "defaultValue": {
                "dc": "默认语言中的基线翻译值"
              },
              "key": {
                "dc": "缺失的翻译键"
              },
              "sourceKey": {
                "dc": "基线来源标识，如 core 或具体 plugin_id"
              },
              "sourceType": {
                "dc": "基线来源类型：host_file=宿主文件 plugin_file=插件文件 database=数据库覆写"
              }
            }
          },
          "MissingMessagesReq": {
            "fields": {
              "keyPrefix": {
                "dc": "按翻译键前缀过滤，如 menu.、plugin.demo.；不传则检查全部"
              },
              "locale": {
                "dc": "目标语言编码，不传时按请求上下文自动解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "检查目标语言相对当前默认语言缺失的翻译键，返回默认语言基线值和来源范围，供交付项目补齐翻译资源",
              "summary": "检查缺失翻译",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "defaultLocale": {
                            "dc": "当前宿主默认语言编码"
                          },
                          "items": {
                            "dc": "缺失翻译键列表"
                          },
                          "locale": {
                            "dc": "目标语言编码"
                          },
                          "total": {
                            "dc": "缺失翻译键数量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "检查目标语言相对当前默认语言缺失的翻译键，返回默认语言基线值和来源范围，供交付项目补齐翻译资源"
            }
          },
          "MissingMessagesRes": {
            "fields": {
              "defaultLocale": {
                "dc": "当前宿主默认语言编码"
              },
              "items": {
                "dc": "缺失翻译键列表"
              },
              "locale": {
                "dc": "目标语言编码"
              },
              "total": {
                "dc": "缺失翻译键数量"
              }
            }
          },
          "RuntimeLocaleItem": {
            "fields": {
              "isDefault": {
                "dc": "是否为宿主默认语言：true=是 false=否"
              },
              "locale": {
                "dc": "语言编码，如 zh-CN、en-US"
              },
              "name": {
                "dc": "按当前展示语言本地化后的语言名称"
              },
              "nativeName": {
                "dc": "该语言自己的原生名称"
              }
            }
          },
          "RuntimeLocalesReq": {
            "fields": {
              "lang": {
                "dc": "名称展示使用的语言编码；不传时按请求上下文自动解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "返回宿主当前支持的运行时语言列表，包含语言编码、默认标记、展示名称和原生名称，供登录页、工作台或交付工具构建语言切换器",
              "summary": "获取运行时语言列表",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "items": {
                            "dc": "宿主当前支持的运行时语言列表"
                          },
                          "locale": {
                            "dc": "本次请求最终生效的展示语言编码"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "返回宿主当前支持的运行时语言列表，包含语言编码、默认标记、展示名称和原生名称，供登录页、工作台或交付工具构建语言切换器"
            }
          },
          "RuntimeLocalesRes": {
            "fields": {
              "items": {
                "dc": "宿主当前支持的运行时语言列表"
              },
              "locale": {
                "dc": "本次请求最终生效的展示语言编码"
              }
            }
          },
          "RuntimeMessagesReq": {
            "fields": {
              "lang": {
                "dc": "目标语言编码；不传时按请求上下文自动解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "返回宿主与已接入资源聚合后的运行时国际化消息包，供登录页、管理工作台和宿主嵌入式插件页面加载",
              "summary": "获取运行时国际化消息包",
              "tags": "国际化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "locale": {
                            "dc": "本次请求最终生效的语言编码"
                          },
                          "messages": {
                            "dc": "聚合后的运行时国际化消息集合"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "返回宿主与已接入资源聚合后的运行时国际化消息包，供登录页、管理工作台和宿主嵌入式插件页面加载"
            }
          },
          "RuntimeMessagesRes": {
            "fields": {
              "locale": {
                "dc": "本次请求最终生效的语言编码"
              },
              "messages": {
                "dc": "聚合后的运行时国际化消息集合"
              }
            }
          }
        }
      }
    }
  }
}
