                "dc": "执行状态"
              },
              "trigger": {
                "dc": "触发方式（cron/manual）"
              }
            }
          },
          "ListReq": {
            "fields": {
              "beginTime": {
                "dc": "按开始时间下界筛选"
              },
              "endTime": {
                "dc": "按开始时间上界筛选"
              },
              "jobId": {
                "dc": "按任务ID筛选，不传则查询全部"
              },
              "nodeId": {
                "dc": "按执行节点标识筛选"
              },
              "orderBy": {
                "dc": "排序字段：id,start_at,end_at,duration_ms,status,created_at"
              },
              "orderDirection": {
                "dc": "排序方向：asc=升序 desc=降序",
                "default": "desc"
              },
              "status": {
                "dc": "按日志状态筛选，不传则查询全部"
              },
              "trigger": {
                "dc": "按触发方式筛选：cron=定时触发 manual=手动触发，不传则查询全部"
              }
            },
            "meta": {
              "dc": "分页查询任务执行日志，支持按任务、状态、触发方式、节点与时间范围筛选",
              "summary": "获取执行日志列表",
              "tags": "任务调度/执行日志"
            },
            "responses": {
