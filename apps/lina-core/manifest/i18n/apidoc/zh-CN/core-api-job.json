      "job": {
        "v1": {
          "CreateReq": {
            "fields": {
              "concurrency": {
                "dc": "并发策略：singleton=单例 parallel=并行",
                "default": "singleton"
              },
              "cronExpr": {
                "dc": "Cron 表达式，支持5段（分 时 日 月 周）与6段（秒 分 时 日 月 周）；5段保存时会自动补 # 秒占位"
              },
              "description": {
                "dc": "任务描述"
              },
              "env": {
                "dc": "Shell 环境变量键值对，仅 Shell 任务使用"
              },
              "groupId": {
                "dc": "所属分组ID"
              },
              "handlerRef": {
                "dc": "Handler 唯一引用；公共创建/编辑接口固定留空"
              },
              "logRetentionOverride": {
                "dc": "任务级日志保留策略；不传则跟随系统参数 cron.log.retention"
              },
              "maxConcurrency": {
                "dc": "最大并发数；concurrency=parallel 时生效"
              },
              "maxExecutions": {
                "dc": "最大执行次数：0=无限制"
              },
              "name": {
                "dc": "任务名称，分组内唯一"
              },
              "params": {
                "dc": "Handler 参数对象；公共创建/编辑接口固定为空对象"
              },
              "scope": {
                "dc": "调度范围：master_only=仅主节点执行 all_node=所有节点执行",
                "default": "master_only"
              },
              "shellCmd": {
                "dc": "Shell 脚本内容；taskType=shell 时必填"
              },
              "status": {
                "dc": "任务状态：enabled=启用 disabled=停用；paused_by_plugin 为系统托管状态，不允许创建或编辑时写入",
                "default": "disabled"
              },
              "taskType": {
                "dc": "任务类型：公共创建/编辑接口仅允许 shell=Shell 任务；Handler 任务由源码注册"
              },
              "timeoutSeconds": {
                "dc": "执行超时时间，单位为秒，范围 1-86400"
              },
              "timezone": {
                "dc": "任务时区标识",
                "default": "Asia/Shanghai"
              },
              "workDir": {
                "dc": "Shell 工作目录，不传则使用宿主当前工作目录"
              }
            },
            "meta": {
              "dc": "创建一个新的用户自建 Shell 定时任务；Handler 类型任务仅允许由宿主或插件源码注册",
              "summary": "创建任务",
              "tags": "任务调度/定时任务"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "id": {
                            "dc": "新建任务ID"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "创建一个新的用户自建 Shell 定时任务；Handler 类型任务仅允许由宿主或插件源码注册"
