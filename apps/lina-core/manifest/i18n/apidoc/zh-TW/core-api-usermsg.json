{
  "core": {
    "api": {
      "usermsg": {
        "v1": {
          "ClearReq": {
            "meta": {
              "dc": "清空當前用戶的所有消息記錄，包括已讀和未讀",
              "summary": "清空全部消息",
              "tags": "用戶消息"
            },
            "schema": {
              "dc": "清空當前用戶的所有消息記錄，包括已讀和未讀"
            }
          },
          "CountReq": {
            "meta": {
              "dc": "獲取當前登錄用戶的未讀消息數量，用於前端消息圖標角標展示",
              "summary": "獲取未讀消息數量",
              "tags": "用戶消息"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "count": {
                            "dc": "未讀消息數量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "獲取當前登錄用戶的未讀消息數量，用於前端消息圖標角標展示"
            }
          },
          "CountRes": {
            "fields": {
              "count": {
                "dc": "未讀消息數量"
              }
            }
          },
          "DeleteReq": {
            "fields": {
              "id": {
                "dc": "消息ID"
              }
            },
            "meta": {
              "dc": "刪除當前用戶的指定消息",
              "summary": "刪除單條消息",
              "tags": "用戶消息"
            },
            "schema": {
              "dc": "刪除當前用戶的指定消息"
            }
          },
          "GetReq": {
            "fields": {
              "id": {
                "dc": "消息ID"
              }
            },
            "meta": {
              "dc": "獲取當前登錄用戶的一條消息詳情，返回預覽彈窗所需的標題、內容、消息類型和發送者信息",
              "summary": "獲取消息詳情",
              "tags": "用戶消息"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "categoryCode": {
                            "dc": "發送方聲明的不透明消息類目編碼（如 notice、announcement、system、alert）。宿主與插件在 i18n 鍵 notify.category.{code}.label 與 notify.category.{code}.color 註冊翻譯，使預覽界面保持類目無關"
                          },
                          "content": {
                            "dc": "可直接用於預覽渲染的消息內容"
                          },
                          "createdAt": {
                            "dc": "消息創建時間"
                          },
                          "createdByName": {
                            "dc": "發送者用戶名"
                          },
                          "id": {
                            "dc": "消息ID"
                          },
                          "sourceId": {
                            "dc": "來源ID"
                          },
                          "sourceType": {
                            "dc": "來源類型：notice=通知公告 plugin=動態插件 system=系統"
                          },
                          "title": {
                            "dc": "消息標題"
                          },
                          "typeColor": {
                            "dc": "由宿主按當前請求語言解析的類目標籤顏色，使預覽組件無需硬編碼類目顏色即可渲染"
                          },
                          "typeLabel": {
                            "dc": "由宿主按當前請求語言解析的類目展示名稱"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "獲取當前登錄用戶的一條消息詳情，返回預覽彈窗所需的標題、內容、消息類型和發送者信息"
            }
          },
          "GetRes": {
            "fields": {
