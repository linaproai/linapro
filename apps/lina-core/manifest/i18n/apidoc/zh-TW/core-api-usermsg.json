              "id": {
                "dc": "消息ID"
              },
              "sourceId": {
                "dc": "來源ID"
              },
              "sourceType": {
                "dc": "來源類型：notice=通知公告 plugin=動態插件 system=系統"
              },
              "title": {
                "dc": "消息標題"
              },
              "typeColor": {
                "dc": "由宿主按當前請求語言解析的類目標籤顏色，使預覽組件無需硬編碼類目顏色即可渲染"
              },
              "typeLabel": {
                "dc": "由宿主按當前請求語言解析的類目展示名稱"
              }
            }
          },
          "ListReq": {
            "meta": {
              "dc": "分頁查詢當前登錄用戶的消息列表，包括已讀和未讀消息",
              "summary": "獲取消息列表",
              "tags": "用戶消息"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "list": {
                            "dc": "消息列表"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "分頁查詢當前登錄用戶的消息列表，包括已讀和未讀消息"
            }
          },
          "ListRes": {
            "fields": {
              "list": {
                "dc": "消息列表"
              }
            }
          },
          "MessageItem": {
            "fields": {
              "categoryCode": {
                "dc": "發送方聲明的不透明消息類目編碼（如 notice、announcement、system、alert）。宿主與插件在 i18n 鍵 notify.category.{code}.label 與 notify.category.{code}.color 註冊翻譯，使收件箱保持類目無關"
              },
              "createdAt": {
                "dc": "消息創建時間"
              },
              "id": {
                "dc": "消息ID"
              },
              "isRead": {
                "dc": "是否已讀：0=未讀 1=已讀"
              },
              "readAt": {
                "dc": "已讀時間，未讀時為空"
              },
              "sourceId": {
                "dc": "來源ID，當前通知公告預覽使用該字段"
              },
              "sourceType": {
                "dc": "來源類型：notice=通知公告 plugin=動態插件 system=系統"
              },
              "title": {
                "dc": "消息標題"
              },
              "typeColor": {
                "dc": "由宿主按當前請求語言解析的類目標籤顏色，使收件箱無需硬編碼類目顏色即可渲染徽標"
              },
              "typeLabel": {
                "dc": "由宿主按當前請求語言解析的類目展示名稱"
              },
              "userId": {
                "dc": "接收用戶ID"
              }
            }
          },
          "ReadAllReq": {
            "meta": {
              "dc": "將當前用戶的所有未讀消息批量標記為已讀",
              "summary": "標記全部消息已讀",
              "tags": "用戶消息"
            },
            "schema": {
              "dc": "將當前用戶的所有未讀消息批量標記為已讀"
            }
          },
          "ReadReq": {
            "fields": {
              "id": {
                "dc": "消息ID"
              }
            },
            "meta": {
              "dc": "將指定消息標記為已讀狀態",
              "summary": "標記消息已讀",
              "tags": "用戶消息"
            },
            "schema": {
              "dc": "將指定消息標記為已讀狀態"
            }
          }
        }
      }
    }
  }
