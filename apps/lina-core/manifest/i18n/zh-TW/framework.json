        },
        "mysql": {
          "description": "關係型數據庫"
        }
      },
      "frontend": {
        "ant-design-vue": {
          "description": "UI組件庫"
        },
        "pinia": {
          "description": "狀態管理"
        },
        "tailwindcss": {
          "description": "原子化CSS框架"
        },
        "typescript": {
