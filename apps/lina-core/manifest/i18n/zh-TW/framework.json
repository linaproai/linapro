{
  "framework": {
    "description": "LinaPro 是一款 AI 驅動的全棧開發框架。"
  },
  "gf": {
    "gvalid": {
      "rule": {
        "between": "{field}字段值應在{min}到{max}之間",
        "in": "{field}字段值不在允許範圍內: {pattern}",
        "length": "{field}字段長度應為{min}到{max}個字符",
        "max": "{field}字段最大值應為{max}",
        "min": "{field}字段最小值應為{min}",
        "required": "{field}字段不能為空"
      }
    }
  },
  "locale": {
    "en-US": {
      "name": "英語",
      "nativeName": "English"
    },
    "zh-CN": {
      "name": "簡體中文",
      "nativeName": "简体中文"
    },
    "zh-TW": {
      "name": "繁體中文",
      "nativeName": "繁體中文"
    }
  },
