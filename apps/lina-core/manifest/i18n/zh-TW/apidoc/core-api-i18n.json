                          "messages": {
                            "dc": "聚合後的運行時國際化消息集合"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "返回宿主與已接入資源聚合後的運行時國際化消息包，供登錄頁、管理工作臺和宿主嵌入式插件頁面加載"
            }
          },
          "RuntimeMessagesRes": {
            "fields": {
              "locale": {
                "dc": "本次請求最終生效的語言編碼"
              },
              "messages": {
                "dc": "聚合後的運行時國際化消息集合"
              }
            }
          }
        }
