                "dc": "命中來源類型：host_file=宿主文件 plugin_file=插件文件"
              },
              "value": {
                "dc": "當前最終生效的翻譯值"
              }
            }
          },
          "MissingMessageItem": {
            "fields": {
              "defaultValue": {
                "dc": "默認語言中的基線翻譯值"
              },
              "key": {
                "dc": "缺失的翻譯鍵"
              },
              "sourceKey": {
                "dc": "基線來源標識，如 core 或具體 plugin_id"
              },
              "sourceType": {
                "dc": "基線來源類型：host_file=宿主文件 plugin_file=插件文件"
              }
            }
          },
          "MissingMessagesReq": {
            "fields": {
              "keyPrefix": {
                "dc": "按翻譯鍵前綴過濾，如 menu.、plugin.demo.；不傳則檢查全部"
              },
              "locale": {
                "dc": "目標語言編碼，不傳時按請求上下文自動解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "檢查目標語言相對當前默認語言缺失的翻譯鍵，返回默認語言基線值和來源範圍，供交付項目補齊翻譯資源",
              "summary": "檢查缺失翻譯",
