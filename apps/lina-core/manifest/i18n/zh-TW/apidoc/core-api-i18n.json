              "locale": {
                "dc": "目標語言編碼"
              },
              "total": {
                "dc": "缺失翻譯鍵數量"
              }
            }
          },
          "RuntimeLocaleItem": {
            "fields": {
              "isDefault": {
                "dc": "是否為宿主默認語言：true=是 false=否"
              },
              "direction": {
                "dc": "語言文本方向，當前宿主約定固定為 ltr"
              },
              "locale": {
                "dc": "語言編碼，如 zh-CN、en-US"
              },
              "name": {
                "dc": "按當前展示語言本地化後的語言名稱"
              },
              "nativeName": {
                "dc": "該語言自己的原生名稱"
              }
            }
          },
          "RuntimeLocalesReq": {
            "fields": {
              "lang": {
                "dc": "名稱展示使用的語言編碼；不傳時按請求上下文自動解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "返回運行時多語言切換狀態和宿主當前支持的語言列表，包含語言編碼、默認標記、展示名稱、原生名稱和固定 LTR 文本方向，供登錄頁、工作臺或交付工具構建語言切換器",
              "summary": "獲取運行時語言列表",
              "tags": "國際化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "enabled": {
                            "dc": "是否開啟運行時多語言切換：true=可顯示語言切換器，false=僅使用默認語言"
                          },
                          "items": {
                            "dc": "宿主當前支持的運行時語言列表"
                          },
                          "locale": {
                            "dc": "本次請求最終生效的展示語言編碼"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "返回運行時多語言切換狀態和宿主當前支持的語言列表，包含語言編碼、默認標記、展示名稱和原生名稱，供登錄頁、工作臺或交付工具構建語言切換器"
            }
          },
          "RuntimeLocalesRes": {
            "fields": {
              "enabled": {
                "dc": "是否開啟運行時多語言切換：true=可顯示語言切換器，false=僅使用默認語言"
              },
              "items": {
                "dc": "宿主當前支持的運行時語言列表"
              },
              "locale": {
                "dc": "本次請求最終生效的展示語言編碼"
              }
            }
          },
          "RuntimeMessagesReq": {
            "fields": {
              "lang": {
                "dc": "目標語言編碼；不傳時按請求上下文自動解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "返回宿主與已接入資源聚合後的運行時國際化消息包，供登錄頁、管理工作臺和宿主嵌入式插件頁面加載",
              "summary": "獲取運行時國際化消息包",
              "tags": "國際化"
