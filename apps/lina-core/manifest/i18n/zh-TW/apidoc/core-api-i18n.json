{
  "core": {
    "api": {
      "i18n": {
        "v1": {
          "DiagnoseMessagesReq": {
            "fields": {
              "keyPrefix": {
                "dc": "按翻譯鍵前綴過濾，如 menu.、plugin.demo.；不傳則診斷全部"
              },
              "locale": {
                "dc": "目標語言編碼，不傳時按請求上下文自動解析，如 zh-CN、en-US"
              }
            },
            "meta": {
              "dc": "診斷目標語言每個翻譯鍵的實際命中來源、是否回退到默認語言以及最終生效的語言，便於排查覆寫優先級與缺失翻譯問題",
              "summary": "診斷翻譯來源",
              "tags": "國際化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "defaultLocale": {
                            "dc": "當前宿主默認語言編碼"
                          },
                          "items": {
                            "dc": "翻譯來源診斷結果列表"
                          },
                          "locale": {
                            "dc": "目標語言編碼"
                          },
                          "total": {
                            "dc": "診斷返回的翻譯鍵數量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "診斷目標語言每個翻譯鍵的實際命中來源、是否回退到默認語言以及最終生效的語言，便於排查覆寫優先級與缺失翻譯問題"
            }
          },
          "DiagnoseMessagesRes": {
            "fields": {
              "defaultLocale": {
                "dc": "當前宿主默認語言編碼"
              },
              "items": {
                "dc": "翻譯來源診斷結果列表"
              },
              "locale": {
                "dc": "目標語言編碼"
              },
              "total": {
                "dc": "診斷返回的翻譯鍵數量"
              }
            }
          },
          "ExportMessagesReq": {
            "fields": {
              "locale": {
                "dc": "目標語言編碼，不傳時按請求上下文自動解析，如 zh-CN、en-US"
              },
              "raw": {
                "dc": "是否僅導出當前語言原始資源：true=僅導出當前語言聚合結果 false=導出帶默認語言回退的有效結果"
              }
            },
            "meta": {
              "dc": "導出指定語言的扁平國際化消息集合，支持導出有效聚合結果或當前語言原始資源，用於交付維護、離線校對和資源文件維護",
              "summary": "導出國際化消息",
              "tags": "國際化"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "defaultLocale": {
                            "dc": "當前宿主默認語言編碼"
                          },
                          "locale": {
                            "dc": "本次導出的目標語言編碼"
                          },
                          "messages": {
                            "dc": "按扁平 key 輸出的國際化消息集合"
                          },
                          "mode": {
                            "dc": "導出模式：effective=帶默認語言回退的有效結果 raw=當前語言原始資源"
                          },
                          "total": {
                            "dc": "導出的翻譯鍵數量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "導出指定語言的扁平國際化消息集合，支持導出有效聚合結果或當前語言原始資源，用於交付維護、離線校對和資源文件維護"
            }
          },
