                          },
                          "items": {
                            "dc": "缺失翻譯鍵列表"
                          },
                          "locale": {
                            "dc": "目標語言編碼"
                          },
                          "total": {
                            "dc": "缺失翻譯鍵數量"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "檢查目標語言相對當前默認語言缺失的翻譯鍵，返回默認語言基線值和來源範圍，供交付項目補齊翻譯資源"
            }
          },
          "MissingMessagesRes": {
            "fields": {
              "defaultLocale": {
                "dc": "當前宿主默認語言編碼"
              },
              "items": {
                "dc": "缺失翻譯鍵列表"
