{
  "core": {
    "api": {
      "job": {
        "v1": {
          "CreateReq": {
            "fields": {
              "concurrency": {
                "dc": "併發策略：singleton=單例 parallel=並行",
                "default": "singleton"
              },
              "cronExpr": {
                "dc": "Cron 表達式，支持5段（分 時 日 月 周）與6段（秒 分 時 日 月 周）；5段保存時會自動補 # 秒佔位"
              },
              "description": {
                "dc": "任務描述"
              },
              "env": {
                "dc": "Shell 環境變量鍵值對，僅 Shell 任務使用"
              },
              "groupId": {
                "dc": "所屬分組ID"
              },
              "handlerRef": {
                "dc": "Handler 唯一引用；公共創建/編輯接口固定留空"
              },
              "logRetentionOverride": {
                "dc": "任務級日誌保留策略；不傳則跟隨系統參數 cron.log.retention"
              },
              "maxConcurrency": {
                "dc": "最大併發數；concurrency=parallel 時生效"
              },
              "maxExecutions": {
                "dc": "最大執行次數：0=無限制"
              },
              "name": {
                "dc": "任務名稱，分組內唯一"
              },
              "params": {
                "dc": "Handler 參數對象；公共創建/編輯接口固定為空對象"
              },
              "scope": {
                "dc": "調度範圍：master_only=僅主節點執行 all_node=所有節點執行",
                "default": "master_only"
              },
              "shellCmd": {
                "dc": "Shell 腳本內容；taskType=shell 時必填"
              },
              "status": {
                "dc": "任務狀態：enabled=啟用 disabled=停用；paused_by_plugin 為系統託管狀態，不允許創建或編輯時寫入",
                "default": "disabled"
              },
              "taskType": {
                "dc": "任務類型：公共創建/編輯接口僅允許 shell=Shell 任務；Handler 任務由源碼註冊"
              },
              "timeoutSeconds": {
                "dc": "執行超時時間，單位為秒，範圍 1-86400"
              },
              "timezone": {
                "dc": "任務時區標識",
                "default": "Asia/Shanghai"
              },
              "workDir": {
                "dc": "Shell 工作目錄，不傳則使用宿主當前工作目錄"
              }
            },
            "meta": {
              "dc": "創建一個新的用戶自建 Shell 定時任務；Handler 類型任務僅允許由宿主或插件源碼註冊",
              "summary": "創建任務",
              "tags": "任務調度/定時任務"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "id": {
                            "dc": "新建任務ID"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "創建一個新的用戶自建 Shell 定時任務；Handler 類型任務僅允許由宿主或插件源碼註冊"
            }
          },
          "CreateRes": {
            "fields": {
              "id": {
                "dc": "新建任務ID"
              }
            }
          },
          "CronPreviewReq": {
            "fields": {
              "expr": {
                "dc": "待預覽的 Cron 表達式，支持5段與6段寫法"
              },
