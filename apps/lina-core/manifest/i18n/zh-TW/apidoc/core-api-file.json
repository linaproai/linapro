{
  "core": {
    "api": {
      "file": {
        "v1": {
          "AccessReq": {
            "fields": {
              "path": {
                "dc": "上傳文件 URL 中返回的相對存儲對象路徑；必須匹配文件元數據記錄，並通過已配置的存儲後端解析"
              }
            },
            "meta": {
              "dc": "通過文件記錄中的存儲路徑讀取已上傳文件，並返回文件二進制內容。該公開接口用於瀏覽器直接訪問已上傳的圖片和文件，但仍要求匹配文件元數據記錄，並且不會解析任意本地文件系統路徑",
              "summary": "訪問已上傳文件",
              "tags": "文件管理"
            },
            "schema": {
              "dc": "通過文件記錄中的存儲路徑讀取已上傳文件，並返回文件二進制內容。該公開接口用於瀏覽器直接訪問已上傳的圖片和文件，但仍要求匹配文件元數據記錄，並且不會解析任意本地文件系統路徑"
            }
          },
          "DeleteReq": {
            "fields": {
              "ids": {
                "dc": "文件ID，多個用逗號分隔"
              }
            },
            "meta": {
              "dc": "根據文件ID刪除文件，支持批量刪除（逗號分隔多個ID）。同時刪除物理文件和數據庫記錄",
              "summary": "刪除文件",
              "tags": "文件管理"
            },
            "schema": {
              "dc": "根據文件ID刪除文件，支持批量刪除（逗號分隔多個ID）。同時刪除物理文件和數據庫記錄"
            }
          },
          "DetailReq": {
            "fields": {
              "id": {
                "dc": "文件ID"
              }
            },
            "meta": {
              "dc": "根據文件ID查詢文件完整詳細信息，包括文件基本信息、上傳者名稱和使用場景",
              "summary": "獲取文件詳情",
              "tags": "文件管理"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "createdBy": {
                            "dc": "上傳者用戶ID"
                          },
                          "createdByName": {
                            "dc": "上傳者用戶名"
                          },
                          "engine": {
                            "dc": "存儲引擎：local=本地"
                          },
                          "hash": {
                            "dc": "文件SHA-256散列值，用於去重"
                          },
                          "id": {
                            "dc": "文件ID"
                          },
                          "name": {
                            "dc": "存儲文件名"
                          },
                          "original": {
                            "dc": "原始文件名"
                          },
                          "path": {
                            "dc": "文件存儲路徑"
                          },
                          "scene": {
                            "dc": "使用場景"
                          },
                          "sceneLabel": {
                            "dc": "使用場景名稱"
                          },
                          "size": {
                            "dc": "文件大小（字節）"
                          },
                          "suffix": {
                            "dc": "文件後綴"
                          },
                          "url": {
                            "dc": "文件訪問URL"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
