                          "framework": {
                            "dc": "框架信息"
                          },
                          "frontendComponents": {
                            "dc": "前端组件列表"
                          },
                          "gfVersion": {
                            "dc": "GoFrame版本"
                          },
                          "goVersion": {
                            "dc": "Go版本"
                          },
                          "os": {
                            "dc": "操作系统"
                          },
                          "runDuration": {
                            "dc": "系统运行时长"
                          },
                          "runDurationSeconds": {
                            "dc": "以总秒数表示的系统运行时长，用于客户端结构化格式化"
                          },
                          "startTime": {
                            "dc": "系统启动时间"
                          }
                        }
