                "dc": "备注"
              },
              "sort": {
                "dc": "显示排序（数字越小越靠前）"
              },
              "status": {
                "dc": "状态：1=正常 0=停用"
              },
              "type": {
                "dc": "菜单类型：D=目录 M=菜单 B=按钮"
              },
              "visible": {
                "dc": "是否显示：1=显示 0=隐藏"
              }
            },
            "meta": {
              "dc": "创建新菜单，支持目录、菜单、按钮三种类型。菜单名称在同一父级下不能重复；左侧导航中的目录/菜单图标必须全局唯一，重复图标将拒绝保存",
              "summary": "创建菜单",
              "tags": "菜单管理"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "id": {
                            "dc": "创建的菜单ID"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
