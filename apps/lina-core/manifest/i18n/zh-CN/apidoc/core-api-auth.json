{
  "core": {
    "api": {
      "auth": {
        "v1": {
          "LoginReq": {
            "fields": {
              "clientType": {
                "dc": "用户会话客户端类型。允许值：web、mobile、desktop、cli"
              },
              "password": {
                "dc": "密码"
              },
              "username": {
                "dc": "用户名"
              }
            },
            "meta": {
              "dc": "通过用户名和密码进行身份认证，认证成功后返回JWT令牌用于后续接口鉴权",
              "summary": "用户登录",
              "tags": "身份认证"
            },
            "responses": {
              "200": {
                "content": {
                  "application_json": {
                    "fields": {
                      "data": {
                        "fields": {
                          "accessToken": {
                            "dc": "JWT令牌"
                          },
                          "refreshToken": {
                            "dc": "JWT刷新令牌"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "schema": {
              "dc": "通过用户名和密码进行身份认证，认证成功后返回JWT令牌用于后续接口鉴权"
            }
          },
          "LoginRes": {
            "fields": {
              "accessToken": {
                "dc": "JWT令牌；需要选择租户时为空"
              },
              "refreshToken": {
                "dc": "JWT刷新令牌；需要选择租户时为空"
              },
              "preToken": {
                "dc": "需要选择租户时返回的短期预登录令牌"
              },
              "tenants": {
                "dc": "需要选择租户时返回的候选租户列表"
              }
            }
          },
          "LoginTenantEntity": {
            "fields": {
              "id": {
                "dc": "租户ID"
              },
              "code": {
                "dc": "租户编码"
              },
              "name": {
                "dc": "租户显示名称"
              },
              "status": {
                "dc": "租户状态"
              }
            }
          },
          "LogoutReq": {
            "meta": {
              "dc": "退出当前登录状态，清除服务端JWT令牌缓存",
              "summary": "用户登出",
              "tags": "身份认证"
            },
            "schema": {
              "dc": "退出当前登录状态，清除服务端JWT令牌缓存"
            }
          },
          "RefreshReq": {
            "fields": {
              "refreshToken": {
                "dc": "JWT刷新令牌"
              }
            },
            "meta": {
              "dc": "使用有效刷新令牌换取新的访问令牌，避免用户在访问令牌过期后被立即强制重新登录。",
              "summary": "刷新访问令牌",
              "tags": "身份认证"
            },
            "schema": {
              "dc": "使用有效刷新令牌换取新的访问令牌，避免用户在访问令牌过期后被立即强制重新登录。"
            }
          },
          "RefreshRes": {
            "fields": {
              "accessToken": {
                "dc": "新的JWT访问令牌"
              },
              "refreshToken": {
                "dc": "当前会话继续使用的JWT刷新令牌"
              }
            }
          },
          "RegisterReq": {
            "fields": {
              "email": {
                "dc": "用于找回密码的邮箱地址"
              },
              "nickname": {
                "dc": "可选显示名称；默认使用用户名"
              },
              "password": {
                "dc": "密码"
              },
              "username": {
                "dc": "用户名"
              }
            },
            "meta": {
              "dc": "在开启自助注册时创建一个平台账号。需要唯一的用户名和邮箱，并分配内置标准用户角色。",
              "summary": "公开注册账号",
              "tags": "身份认证"
            },
            "schema": {
              "dc": "在开启自助注册时创建一个平台账号。需要唯一的用户名和邮箱，并分配内置标准用户角色。"
            }
          },
          "RegisterRes": {
            "fields": {
              "userId": {
                "dc": "新创建的用户ID"
              }
            }
          },
          "ForgetPasswordReq": {
            "fields": {
              "email": {
                "dc": "账号邮箱地址"
              }
            },
            "meta": {
              "dc": "在开启密码找回且邮件投递可用时，若存在匹配的启用账号，则向该邮箱发送一次性重置链接。响应始终为成功形态，以避免账号枚举。",
              "summary": "请求发送密码重置邮件",
              "tags": "身份认证"
            },
            "schema": {
              "dc": "在开启密码找回且邮件投递可用时，若存在匹配的启用账号，则向该邮箱发送一次性重置链接。响应始终为成功形态，以避免账号枚举。"
            }
          },
          "ForgetPasswordRes": {
            "fields": {
              "accepted": {
                "dc": "是否已接受找回请求"
              }
            }
          },
          "ResetPasswordReq": {
            "fields": {
              "password": {
                "dc": "新密码"
              },
              "token": {
                "dc": "找回邮件中的一次性密码重置令牌"
              }
            },
            "meta": {
              "dc": "消费一次性密码重置令牌，并为关联账号设置新密码。",
              "summary": "确认密码重置",
              "tags": "身份认证"
            },
            "schema": {
              "dc": "消费一次性密码重置令牌，并为关联账号设置新密码。"
            }
          },
          "ResetPasswordRes": {
            "fields": {
              "reset": {
                "dc": "密码是否已成功重置"
              }
            }
          }
        }
      }
    }
  }
}
