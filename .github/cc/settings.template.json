{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_AUTH_TOKEN}",
    "ANTHROPIC_BASE_URL": "${ANTHROPIC_BASE_URL}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${ANTHROPIC_CUSTOM_MODEL}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${ANTHROPIC_CUSTOM_MODEL}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${ANTHROPIC_CUSTOM_MODEL}",
    "ANTHROPIC_MODEL": "${ANTHROPIC_CUSTOM_MODEL}",
    "ANTHROPIC_REASONING_MODEL": "${ANTHROPIC_CUSTOM_MODEL}",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "${ANTHROPIC_CUSTOM_MODEL}",
  "skipDangerousModePermissionPrompt": true
}